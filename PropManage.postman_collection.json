{
  "info": {
    "name": "Property Management SaaS",
    "description": "Postman collection for Property Management SaaS backend (auth, users, admins, organizations, subscriptions, buildings, floors, units, tenants, leases, invoices, payments). Base URL is set via the `baseUrl` collection variable. After /login the access token is captured to `{{accessToken}}` automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "0a3a9c2c-3e0b-4d7e-9c1b-1f1f1f1f1f1f"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "adminId", "value": "", "type": "string" },
    { "key": "buildingId", "value": "", "type": "string" },
    { "key": "floorId", "value": "", "type": "string" },
    { "key": "unitId", "value": "", "type": "string" },
    { "key": "tenantId", "value": "", "type": "string" },
    { "key": "leaseId", "value": "", "type": "string" },
    { "key": "invoiceId", "value": "", "type": "string" },
    { "key": "paymentId", "value": "", "type": "string" },
    { "key": "caretakerId", "value": "", "type": "string" },
    { "key": "organizationId", "value": "", "type": "string" },
    { "key": "expenseId", "value": "", "type": "string" },
    { "key": "complaintId", "value": "", "type": "string" },
    { "key": "documentId", "value": "", "type": "string" },
    { "key": "notificationId", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Owner",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Aziz Sajib\",\n  \"email\": \"owner@example.com\",\n  \"password\": \"password123\",\n  \"contactNumber\": \"01711000111\",\n  \"organization\": {\n    \"name\": \"Sajib Properties Ltd.\",\n    \"slug\": \"sajib-properties\",\n    \"phone\": \"01711000111\",\n    \"email\": \"info@sajibprops.com\",\n    \"address\": \"Lalmatia, Dhaka\"\n  }\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const json = pm.response.json();",
                  "  const token = json?.data?.accessToken || json?.accessToken || json?.token;",
                  "  if (token) {",
                  "    pm.collectionVariables.set('accessToken', token);",
                  "    console.log('accessToken saved');",
                  "  }",
                  "} catch (e) { console.log('No JSON body to parse'); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/refresh-token", "host": ["{{baseUrl}}"], "path": ["auth", "refresh-token"] },
            "body": { "mode": "raw", "raw": "{}" },
            "description": "Refresh token is read from the `refreshToken` cookie set during login."
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/change-password", "host": ["{{baseUrl}}"], "path": ["auth", "change-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"newPassword123\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        },
        {
          "name": "Verify Email (OTP)",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/verify-email", "host": ["{{baseUrl}}"], "path": ["auth", "verify-email"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@example.com\",\n  \"otp\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Forget Password",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/forget-password", "host": ["{{baseUrl}}"], "path": ["auth", "forget-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@example.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["auth", "reset-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@example.com\",\n  \"otp\": \"123456\",\n  \"newPassword\": \"newPassword123\"\n}"
            }
          }
        },
        {
          "name": "Google OAuth — Start",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/auth/login/google", "host": ["{{baseUrl}}"], "path": ["auth", "login", "google"] },
            "description": "Open this URL in a browser to initiate Google OAuth — won't complete inside Postman."
          }
        },
        {
          "name": "Google OAuth — Success Callback",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/auth/google/success", "host": ["{{baseUrl}}"], "path": ["auth", "google", "success"] }
          }
        },
        {
          "name": "Google OAuth — Error",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/auth/oauth/error", "host": ["{{baseUrl}}"], "path": ["auth", "oauth", "error"] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create Staff (Manager / Caretaker)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users/create-staff", "host": ["{{baseUrl}}"], "path": ["users", "create-staff"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"staffPass123\",\n  \"role\": \"MANAGER\",\n  \"user\": {\n    \"name\": \"Hasan Ali\",\n    \"email\": \"hasan@example.com\",\n    \"contactNumber\": \"01711000222\",\n    \"image\": \"https://example.com/hasan.png\"\n  },\n  \"buildingIds\": []\n}"
            },
            "description": "Allowed: OWNER, SUPER_ADMIN. `role` must be MANAGER or CARETAKER."
          }
        },
        {
          "name": "Create Tenant",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users/create-tenant", "host": ["{{baseUrl}}"], "path": ["users", "create-tenant"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant\": {\n    \"name\": \"Rahim Uddin\",\n    \"phone\": \"01711000333\",\n    \"email\": \"rahim@example.com\",\n    \"nidNumber\": \"1234567890\",\n    \"emergencyContact\": \"01711000444\",\n    \"emergencyName\": \"Karim Uddin\",\n    \"occupation\": \"Software Engineer\",\n    \"permanentAddress\": \"Lalmatia, Dhaka\",\n    \"photoUrl\": \"https://example.com/rahim.png\"\n  },\n  \"createLoginAccount\": true,\n  \"password\": \"tenantPass123\"\n}"
            },
            "description": "Allowed: OWNER, MANAGER, CARETAKER. If `createLoginAccount` is true, `password` is required."
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "role", "value": "OWNER", "disabled": true },
                { "key": "search", "value": "rahim", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get User By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}"]
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Aziz Sajib (Updated)\",\n  \"contactNumber\": \"01711999888\",\n  \"image\": \"https://example.com/new.png\",\n  \"isActive\": true\n}"
            }
          }
        },
        {
          "name": "Soft Delete User",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Organizations",
      "item": [
        {
          "name": "Get My Organization",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/organizations/me", "host": ["{{baseUrl}}"], "path": ["organizations", "me"] },
            "description": "Allowed: OWNER, MANAGER, CARETAKER. Returns the caller's organization with its subscription."
          }
        },
        {
          "name": "Update My Organization",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/organizations/me", "host": ["{{baseUrl}}"], "path": ["organizations", "me"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sajib Properties Ltd. (Updated)\",\n  \"logoUrl\": \"https://example.com/logo.png\",\n  \"phone\": \"01711000111\",\n  \"email\": \"info@sajibprops.com\",\n  \"address\": \"House 12, Road 5, Lalmatia, Dhaka\"\n}"
            },
            "description": "Allowed: OWNER only. All fields optional."
          }
        }
      ]
    },
    {
      "name": "Subscriptions",
      "item": [
        {
          "name": "Get All Plans (Public)",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/subscriptions/plans", "host": ["{{baseUrl}}"], "path": ["subscriptions", "plans"] },
            "description": "Public endpoint — returns all available subscription plans with limits and pricing."
          }
        },
        {
          "name": "Get My Subscription",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/subscriptions/me", "host": ["{{baseUrl}}"], "path": ["subscriptions", "me"] },
            "description": "Allowed: OWNER, MANAGER. Returns active subscription for caller's organization (plan, status, limits, trial end date)."
          }
        },
        {
          "name": "Change Plan",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/subscriptions/me/plan", "host": ["{{baseUrl}}"], "path": ["subscriptions", "me", "plan"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan\": \"STANDARD\"\n}"
            },
            "description": "Allowed: OWNER only. Plan must be one of FREE_TRIAL, BASIC, STANDARD, ENTERPRISE."
          }
        },
        {
          "name": "Cancel Subscription",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/subscriptions/me/cancel", "host": ["{{baseUrl}}"], "path": ["subscriptions", "me", "cancel"] },
            "description": "Allowed: OWNER only. Cancels the active subscription for the caller's organization."
          }
        },
        {
          "name": "Reactivate Subscription",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/subscriptions/me/reactivate", "host": ["{{baseUrl}}"], "path": ["subscriptions", "me", "reactivate"] },
            "description": "Allowed: OWNER only. Reactivates a previously cancelled subscription."
          }
        },
        {
          "name": "[Admin] List All Subscriptions",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/subscriptions", "host": ["{{baseUrl}}"], "path": ["subscriptions"] },
            "description": "Allowed: SUPER_ADMIN only. Returns all organization subscriptions."
          }
        },
        {
          "name": "[Admin] Update Subscription",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/subscriptions/{{organizationId}}", "host": ["{{baseUrl}}"], "path": ["subscriptions", "{{organizationId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan\": \"ENTERPRISE\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "description": "Allowed: SUPER_ADMIN only. Manually override a subscription for any organization."
          }
        }
      ]
    },
    {
      "name": "Buildings",
      "item": [
        {
          "name": "Create Building",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/buildings", "host": ["{{baseUrl}}"], "path": ["buildings"] },
