          }
        }
      ]
    },
    {
      "name": "Leases",
      "item": [
        {
          "name": "Create Lease",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/leases", "host": ["{{baseUrl}}"], "path": ["leases"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{tenantId}}\",\n  \"unitId\": \"{{unitId}}\",\n  \"startDate\": \"2026-06-01\",\n  \"endDate\": \"2027-05-31\",\n  \"moveInDate\": \"2026-06-01\",\n  \"monthlyRent\": 18000,\n  \"serviceCharge\": 1500,\n  \"securityDeposit\": 36000,\n  \"rentDueDay\": 5\n}"
            },
            "description": "Creates lease, marks unit OCCUPIED, and auto-generates first month invoice."
          }
        },
        {
          "name": "Get All Leases",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/leases", "host": ["{{baseUrl}}"], "path": ["leases"] }
          }
        },
        {
          "name": "Get Lease By Id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/leases/{{leaseId}}", "host": ["{{baseUrl}}"], "path": ["leases", "{{leaseId}}"] }
          }
        },
        {
          "name": "Terminate Lease",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/leases/{{leaseId}}/terminate", "host": ["{{baseUrl}}"], "path": ["leases", "{{leaseId}}", "terminate"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"moveOutDate\": \"2026-12-31\",\n  \"notes\": \"Tenant relocating to another city\"\n}"
            },
            "description": "Marks lease TERMINATED and unit VACANT."
          }
        }
      ]
    },
    {
      "name": "Invoices",
      "item": [
        {
          "name": "Generate Single Invoice",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/invoices/generate", "host": ["{{baseUrl}}"], "path": ["invoices", "generate"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leaseId\": \"{{leaseId}}\",\n  \"billingMonth\": \"2026-07-01\",\n  \"utilityAmount\": 800,\n  \"penaltyAmount\": 0\n}"
            }
          }
        },
        {
          "name": "Generate Monthly Batch",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/invoices/generate-monthly", "host": ["{{baseUrl}}"], "path": ["invoices", "generate-monthly"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"billingMonth\": \"2026-08-01\"\n}"
            },
            "description": "Generates invoices for all ACTIVE leases for the given month. Skips leases that already have an invoice that month."
          }
        },
        {
          "name": "Get All Invoices",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/invoices?status=DUE",
              "host": ["{{baseUrl}}"],
              "path": ["invoices"],
              "query": [
                { "key": "status", "value": "DUE" },
                { "key": "leaseId", "value": "{{leaseId}}", "disabled": true },
                { "key": "tenantId", "value": "{{tenantId}}", "disabled": true },
                { "key": "unitId", "value": "{{unitId}}", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Invoice By Id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/invoices/{{invoiceId}}", "host": ["{{baseUrl}}"], "path": ["invoices", "{{invoiceId}}"] }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Record Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/payments", "host": ["{{baseUrl}}"], "path": ["payments"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"invoiceId\": \"{{invoiceId}}\",\n  \"amount\": 19500,\n  \"method\": \"BKASH\",\n  \"transactionId\": \"9ABC123XYZ\",\n  \"notes\": \"June rent\"\n}"
            },
            "description": "Records payment against invoice. Updates invoice status (PARTIAL/PAID) automatically."
          }
        },
        {
          "name": "Get All Payments",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/payments",
              "host": ["{{baseUrl}}"],
              "path": ["payments"],
              "query": [
                { "key": "leaseId", "value": "{{leaseId}}", "disabled": true },
                { "key": "tenantId", "value": "{{tenantId}}", "disabled": true },
                { "key": "invoiceId", "value": "{{invoiceId}}", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Payment By Id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/payments/{{paymentId}}", "host": ["{{baseUrl}}"], "path": ["payments", "{{paymentId}}"] }
          }
        }
      ]
    },
    {
      "name": "Admins",
      "item": [
        {
          "name": "Get All Admins",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/admins", "host": ["{{baseUrl}}"], "path": ["admins"] },
            "description": "Allowed: ADMIN, SUPER_ADMIN. Returns non-deleted admins with linked user."
          }
        },
        {
          "name": "Get Admin By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admins/{{adminId}}",
              "host": ["{{baseUrl}}"],
              "path": ["admins", "{{adminId}}"]
            }
          }
        },
        {
          "name": "Update Admin",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/admins/{{adminId}}",
              "host": ["{{baseUrl}}"],
              "path": ["admins", "{{adminId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"admin\": {\n    \"name\": \"Super Admin (Updated)\",\n    \"profilePhoto\": \"https://example.com/admin.png\",\n    \"contactNumber\": \"01711555000\"\n  }\n}"
            },
            "description": "Allowed: SUPER_ADMIN only."
          }
        },
        {
          "name": "Soft Delete Admin",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/admins/{{adminId}}",
              "host": ["{{baseUrl}}"],
              "path": ["admins", "{{adminId}}"]
            },
            "description": "Allowed: SUPER_ADMIN only. Marks admin & user as deleted, removes sessions & accounts. Cannot delete yourself."
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": {
              "raw": "http://localhost:5000/",
              "host": ["http://localhost:5000"],
              "path": [""]
            }
          }
        }
      ]
    }
  ]
}
