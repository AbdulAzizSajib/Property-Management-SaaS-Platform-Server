model Invoice {
  id            String        @id @default(uuid(7))
  invoiceNumber String        @unique
  type          InvoiceType   @default(RENT)
  status        PaymentStatus @default(DUE)
  billingMonth  DateTime // which month this invoice is for
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  rentAmount    Decimal       @default(0) @db.Decimal(12, 2)
  serviceCharge Decimal       @default(0) @db.Decimal(12, 2)
  utilityAmount Decimal       @default(0) @db.Decimal(12, 2)
  penaltyAmount Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal       @db.Decimal(12, 2)
  paidAmount    Decimal       @default(0) @db.Decimal(12, 2)
  dueAmount     Decimal       @default(0) @db.Decimal(12, 2)
  notes         String?
  cancelledAt   DateTime?
  cancelReason  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Carry-forward link. When this invoice's unpaid balance is rolled into a
  // newer invoice, its status becomes CARRIED_FORWARD and these fields point to
  // the invoice that absorbed it — letting us reverse the roll-up on cancel.
  carriedForwardToId String?
  carriedForwardTo   Invoice?  @relation("CarryForward", fields: [carriedForwardToId], references: [id], onDelete: SetNull)
  carriedForwardFrom Invoice[] @relation("CarryForward")
  carriedForwardAt   DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  leaseId String
  lease   Lease  @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  payments  Payment[]
  lineItems InvoiceLineItem[]

  @@index([organizationId])
  @@index([leaseId])
  @@index([status])
  @@index([billingMonth])
  @@index([carriedForwardToId])
}
