model Lease {
    id              String      @id @default(cuid())
    status          LeaseStatus @default(ACTIVE)
    startDate       DateTime
    endDate         DateTime?
    moveInDate      DateTime
    moveOutDate     DateTime?
    monthlyRent     Decimal     @db.Decimal(12, 2)
    serviceCharge   Decimal     @default(0) @db.Decimal(12, 2)
    securityDeposit Decimal     @default(0) @db.Decimal(12, 2)
    advanceBalance  Decimal     @default(0) @db.Decimal(12, 2) // unused advance
    rentDueDay      Int         @default(5) // day of month rent is due
    notes           String?
    createdAt       DateTime    @default(now())
    updatedAt       DateTime    @updatedAt

    organizationId String
    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

    unitId String
    unit   Unit   @relation(fields: [unitId], references: [id])

    tenantId String
    tenant   Tenant @relation(fields: [tenantId], references: [id])

    invoices      Invoice[]
    payments      Payment[]
    agreement     RentAgreement?
    rentIncreases RentIncrease[]
    documents     Document[]

    @@index([unitId])
    @@index([tenantId])
    @@index([status])
}
