model Payment {
    id            String        @id @default(cuid())
    receiptNumber String        @unique
    amount        Decimal       @db.Decimal(12, 2)
    method        PaymentMethod @default(CASH)
    status        PaymentStatus @default(PAID)
    paidAt        DateTime      @default(now())
    transactionId String? // bKash/Nagad/SSLCommerz txn id
    isAdvance     Boolean       @default(false) // payment kept as advance
    notes         String?
    receiptUrl    String?
    createdAt     DateTime      @default(now())
    updatedAt     DateTime      @updatedAt

    organizationId String
    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

    invoiceId String?
    invoice   Invoice? @relation(fields: [invoiceId], references: [id])

    leaseId String
    lease   Lease  @relation(fields: [leaseId], references: [id])

    tenantId String
    tenant   Tenant @relation(fields: [tenantId], references: [id])

    // Who recorded the payment (Owner / Manager / Caretaker)
    recordedById String?
    recordedBy   User?   @relation("PaymentRecordedBy", fields: [recordedById], references: [id])

    @@index([organizationId])
    @@index([invoiceId])
    @@index([tenantId])
    @@index([paidAt])
}
