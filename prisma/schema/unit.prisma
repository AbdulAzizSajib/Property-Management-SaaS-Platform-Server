model Unit {
    id            String     @id @default(cuid())
    name          String // e.g. "A-3", "Shop 12"
    type          UnitType   @default(FLAT)
    status        UnitStatus @default(VACANT)
    bedrooms      Int?
    bathrooms     Int?
    drawingRooms  Int?
    diningRooms   Int?
    kitchens      Int?
    balconies     Int?
    sizeSqft      Float?
    baseRent      Decimal    @db.Decimal(12, 2)
    serviceCharge Decimal?   @db.Decimal(12, 2)
    description   String?
    createdAt     DateTime   @default(now())
    updatedAt     DateTime   @updatedAt

    buildingId String
    building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

    floorId String?
    floor   Floor?  @relation(fields: [floorId], references: [id])

    leases     Lease[]
    invoices   Invoice[]
    complaints Complaint[]
    expenses   Expense[]

    @@index([buildingId])
    @@index([floorId])
    @@index([status])
}
